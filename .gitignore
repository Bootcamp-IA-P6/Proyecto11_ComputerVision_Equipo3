# Python / uv
__pycache__/
*.py[cod]
.venv/
.uv/
*.egg-info/
dist/

# Datos y modelos (demasiado grandes para Git)
data/raw/*
data/processed/*
data/augmented/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/augmented/.gitkeep
*.pt
*.weights
*.onnx

# Entorno
.env
*.env

# Jupyter
.ipynb_checkpoints/

# Sistema
.DS_Store
Thumbs.db
.vscode/

# Cachés de datasets YOLO
**/labels.cache

# Caché de Vite (generado por npm run dev)
**/.vite/

# Reports generados
reports/sample_outputs/*
!reports/sample_outputs/.gitkeep

services/backend/app/storage/crops/*.jpg

# Frontend
node_modules/
services/frontend/node_modules/
services/frontend/dist/
services/frontend/.env


